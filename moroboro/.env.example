# YouTube Data API v3 integration keys
# Get your API key from Google Cloud Console: https://console.cloud.google.com/
YOUTUBE_API_KEY=
# Find your YouTube Channel ID in Advanced Settings: https://www.youtube.com/account_advanced
YOUTUBE_CHANNEL_ID=

# Google OAuth2 Credentials
# Set up OAuth 2.0 Client credentials on Google Cloud: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
